<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Extiende el reporte BASE de factura (account.report_invoice_document),
        que es el que se envía por correo y el que se imprime con el botón
        principal. Respeta el external layout configurado (bubble, boxed, etc.).

        La vista nativa del CFDI (l10n_mx_edi) se desactiva en
        report_disable_l10n_mx.xml; aquí se reconstruye TODO con nuestro formato:
          - Tabla interna en el bloque de información con Folio fiscal, Uso CFDI,
            Forma de pago y Método de pago (lo que aportaba la nativa).
          - Pie con sellos digitales, cadena original, QR e Información Extra.
        Todo en letra reducida y solo cuando la factura está timbrada.
    -->
    <template id="report_invoice_document_cfdi_aq" inherit_id="account.report_invoice_document">

        <!-- ============================================================ -->
        <!-- Datos fiscales (tabla propia) DEBAJO del bloque de info       -->
        <!-- Se coloca DESPUÉS de la fila de columnas para no descuadrar    -->
        <!-- el grid (col-auto/col-3) y evitar que se encime todo.         -->
        <!-- ============================================================ -->
        <xpath expr="//div[@id='informations']" position="after">
            <t t-set="d_cfdi" t-value="o._aq_get_cfdi_data()"/>
            <div t-if="d_cfdi.get('uuid')" class="aq-cfdi mt-1" name="aq_cfdi_fiscal">
                <style>
                    .aq-cfdi { font-size: 8px; color: #222; }
                    .aq-cfdi table { width: 100%; border-collapse: collapse; }
                    .aq-cfdi .aq-tbl td { padding: 1px 8px 1px 0; vertical-align: top; }
                    .aq-cfdi .k { font-weight: bold; white-space: nowrap; }
                    .aq-seals { font-size: 8px; color: #222; }
                    .aq-seals table { width: 100%; border-collapse: collapse; }
                    .aq-seals .seal-h { background: #7a7a85; color: #fff;
                        text-align: center; font-weight: bold; font-size: 7px;
                        padding: 1px; margin-top: 6px; }
                    .aq-seals .seal { font-size: 6px; word-break: break-all;
                        line-height: 1.2; padding: 1px; }
                    .aq-seals .qrbox { width: 95px; vertical-align: top; }
                    .aq-seals .qrbox img { width: 90px; height: 90px; }
                    .aq-seals .info-extra { font-size: 6px; line-height: 1.3; margin-top: 4px; }
                    .aq-seals .note { text-align: center; font-size: 6.5px; color: #555;
                        margin-top: 6px; border-top: 1px solid #ccc; padding-top: 3px; }
                </style>
                <table class="aq-tbl">
                    <tr>
                        <td class="k" style="width:13%">Folio fiscal:</td>
                        <td style="width:50%"><span t-esc="d_cfdi['uuid']"/></td>
                        <td class="k" style="width:12%">Uso CFDI:</td>
                        <td><span t-esc="d_cfdi['uso_cfdi']"/> - <span t-esc="d_cfdi['uso_cfdi_nombre']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Forma de pago:</td>
                        <td><span t-esc="d_cfdi['forma_pago']"/></td>
                        <td class="k">Método de pago:</td>
                        <td><span t-esc="d_cfdi['metodo_pago']"/></td>
                    </tr>
                </table>
            </div>
        </xpath>

        <!-- ============================================================ -->
        <!-- Pie: sellos, cadena original, QR e Información Extra          -->
        <!-- ============================================================ -->
        <xpath expr="//div[hasclass('page')]" position="inside">
            <t t-set="d_seal" t-value="o._aq_get_cfdi_data()"/>
            <div t-if="d_seal.get('uuid')" class="aq-seals mt-2">
                <div class="seal-h">Sello digital del CFDI</div>
                <div class="seal"><span t-esc="d_seal['sello_cfdi']"/></div>

                <div class="seal-h">Sello digital del SAT</div>
                <div class="seal"><span t-esc="d_seal['sello_sat']"/></div>

                <div class="seal-h">Cadena original del complemento de certificación digital del SAT</div>
                <table>
                    <tr>
                        <td class="qrbox">
                            <img t-if="d_seal.get('qr_b64')"
                                 t-att-src="'data:image/png;base64,%s' % d_seal['qr_b64']"/>
                        </td>
                        <td style="vertical-align:top">
                            <div class="seal"><span t-esc="d_seal['cadena_sat']"/></div>
                        </td>
                    </tr>
                </table>

                <div class="info-extra">
                    <b>Información Extra:</b>
                    Certificado del emisor: <span t-esc="d_seal['no_certificado']"/> |
                    Certificado SAT: <span t-esc="d_seal['no_certificado_sat']"/> |
                    Lugar de expedición: <span t-esc="d_seal['lugar_expedicion']"/> |
                    Régimen Fiscal: <span t-esc="d_seal['regimen_emisor']"/> |
                    Fecha de Emisión: <span t-esc="d_seal['fecha']"/> |
                    Fecha de Certificación: <span t-esc="d_seal['fecha_timbrado']"/> |
                    Folio Fiscal: <span t-esc="d_seal['uuid']"/>
                </div>

                <div class="note">Este documento es una representación impresa de un CFDI.</div>
            </div>
        </xpath>

    </template>
</odoo>
