<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Reporte de factura (account.report_invoice_document) con identidad
        Alphaqueb sobre BLANCO. Tipografía: Bebas (títulos), Oxanium (datos),
        Roboto (cuerpo). Acentos: lima #B9E856 / púrpura #723FA0 / negro.
        Sin rellenos grises. El QR se mantiene B/N (legibilidad SAT): el .py NO cambia.
    -->
    <template id="report_invoice_document_cfdi_aq" inherit_id="account.report_invoice_document">

        <!-- Datos del CFDI (una vez) + estilos globales y clases reutilizables -->
        <xpath expr="//div[@id='informations']" position="before">
            <t t-set="d_cfdi" t-value="o._aq_get_cfdi_data()"/>
            <style>
                @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=Oxanium:wght@400;600;700&amp;family=Roboto:wght@400;500;700&amp;display=swap');

                .page { font-family: 'Roboto', Arial, sans-serif; font-size: 11px; color: #111111; }
                .page .o_main_table th,
                .page .o_main_table td { padding: 2px 4px; }

                /* Barra de marca (lima + segmento púrpura) */
                .aq-top { width: 100%; border-collapse: collapse; table-layout: fixed; margin: 2px 0 9px; }
                .aq-top td { height: 4px; line-height: 4px; font-size: 0; padding: 0; }
                .aq-top .l { background: #B9E856; }
                .aq-top .p { background: #723FA0; width: 130px; }

                /* Encabezado de sección: acento lima + Bebas negro + filete negro */
                .aq-h { font-family: 'Bebas Kai','Bebas Neue', sans-serif; font-size: 18px;
                    letter-spacing: 1px; text-transform: uppercase; color: #000000;
                    padding-left: 10px; border-left: 4px solid #B9E856; line-height: .95; }
                .aq-h-rule { border-bottom: 1.5px solid #000000; margin: 3px 0 8px; }

                /* Sub-encabezado (sellos) */
                .aq-sh { font-family: 'Bebas Kai','Bebas Neue', sans-serif; font-size: 12px;
                    letter-spacing: .6px; text-transform: uppercase; color: #000000;
                    padding-left: 8px; border-left: 3px solid #B9E856; margin-top: 8px; line-height: 1; }
                .aq-sh-rule { border-bottom: 1px solid #000000; margin: 2px 0 4px; }
            </style>
        </xpath>

        <!-- Oculta el bloque nativo de info SOLO cuando hay CFDI -->
        <xpath expr="//div[@id='informations']" position="attributes">
            <attribute name="t-att-style">d_cfdi.get('uuid') and 'display:none' or ''</attribute>
        </xpath>

        <!-- ============================================================ -->
        <!-- Datos fiscales (grid aireado, sin cajas)                     -->
        <!-- ============================================================ -->
        <xpath expr="//div[@id='informations']" position="after">
            <div t-if="d_cfdi.get('uuid')" class="aq-cfdi mt-2" name="aq_cfdi_fiscal">
                <style>
                    .aq-cfdi { margin-top: 6px; margin-bottom: 12px; }
                    .aq-grid { width: 100%; border-collapse: collapse; table-layout: fixed;
                        font-family: 'Oxanium', Arial, sans-serif; font-size: 11px; color: #111111; }
                    .aq-grid td { padding: 4px 7px; vertical-align: top;
                        border-bottom: 1px solid #ededf0; background: #ffffff; }
                    .aq-grid .k { width: 16%; font-size: 8px; font-weight: 700; letter-spacing: .4px;
                        text-transform: uppercase; color: #723FA0; white-space: nowrap; line-height: 1.45; }
                    .aq-grid td:nth-child(2),
                    .aq-grid td:nth-child(4) { width: 34%; }
                    .aq-grid .uuid { font-weight: 700; color: #000000; letter-spacing: .3px; }
                </style>

                <table class="aq-top"><tr><td class="l">&#160;</td><td class="p">&#160;</td></tr></table>
                <div class="aq-h">Comprobante Fiscal Digital · CFDI</div>
                <div class="aq-h-rule"/>

                <table class="aq-grid">
                    <tr>
                        <td class="k">Folio fiscal</td>
                        <td colspan="3"><span class="uuid" t-esc="d_cfdi['uuid']"/></td>
                    </tr>
                    <tr>
                        <td class="k">RFC emisor</td>
                        <td><span t-esc="d_cfdi['rfc_emisor']"/></td>
                        <td class="k">Nombre emisor</td>
                        <td><span t-esc="d_cfdi['nombre_emisor']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Régimen emisor</td>
                        <td><span t-esc="d_cfdi['regimen_emisor']"/> - <span t-esc="d_cfdi['regimen_emisor_nombre']"/></td>
                        <td class="k">No. serie CSD</td>
                        <td><span t-esc="d_cfdi['no_certificado']"/></td>
                    </tr>
                    <tr>
                        <td class="k">RFC receptor</td>
                        <td><span t-esc="d_cfdi['rfc_receptor']"/></td>
                        <td class="k">Nombre receptor</td>
                        <td><span t-esc="d_cfdi['nombre_receptor']"/></td>
                    </tr>
                    <tr>
                        <td class="k">CP receptor</td>
                        <td><span t-esc="d_cfdi['cp_receptor']"/></td>
                        <td class="k">Régimen receptor</td>
                        <td><span t-esc="d_cfdi['regimen_receptor']"/> - <span t-esc="d_cfdi['regimen_receptor_nombre']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Uso CFDI</td>
                        <td><span t-esc="d_cfdi['uso_cfdi']"/> - <span t-esc="d_cfdi['uso_cfdi_nombre']"/></td>
                        <td class="k">Efecto</td>
                        <td><span t-esc="d_cfdi['tipo_comprobante']"/> - <span t-esc="d_cfdi['tipo_comprobante_nombre']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Exportación</td>
                        <td><span t-esc="d_cfdi['exportacion']"/> - <span t-esc="d_cfdi['exportacion_nombre']"/></td>
                        <td class="k">Lugar expedición</td>
                        <td><span t-esc="d_cfdi['lugar_expedicion']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Serie / Folio</td>
                        <td><span t-esc="d_cfdi['serie_folio']"/></td>
                        <td class="k">Emisión</td>
                        <td><span t-esc="d_cfdi['fecha']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Fecha factura</td>
                        <td><span t-field="o.invoice_date"/></td>
                        <td class="k">Fecha límite</td>
                        <td><span t-field="o.invoice_date_due"/></td>
                    </tr>
                    <tr>
                        <td class="k">Origen</td>
                        <td><span t-esc="o.invoice_origin"/></td>
                        <td class="k">Referencia</td>
                        <td><span t-esc="o.ref"/></td>
                    </tr>
                    <tr>
                        <td class="k">Moneda</td>
                        <td><span t-esc="d_cfdi['moneda']"/> - <span t-esc="d_cfdi['moneda_nombre']"/></td>
                        <td class="k">Certificación</td>
                        <td><span t-esc="d_cfdi['fecha_timbrado']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Forma de pago</td>
                        <td><span t-esc="d_cfdi['forma_pago_label']"/></td>
                        <td class="k">Método de pago</td>
                        <td><span t-esc="d_cfdi['metodo_pago_label']"/></td>
                    </tr>
                    <tr>
                        <td class="k">CSD SAT</td>
                        <td colspan="3"><span t-esc="d_cfdi['no_certificado_sat']"/></td>
                    </tr>
                </table>
            </div>
        </xpath>

        <!-- ============================================================ -->
        <!-- Conceptos: cabecera negra + borde inferior lima              -->
        <!-- ============================================================ -->
        <xpath expr="//table[hasclass('o_main_table')]" position="attributes">
            <attribute name="t-att-style">d_cfdi.get('uuid') and 'display:none' or ''</attribute>
        </xpath>

        <xpath expr="//table[hasclass('o_main_table')]" position="before">
            <div t-if="d_cfdi.get('uuid')" class="aq-cpt" name="aq_cfdi_conceptos">
                <style>
                    .aq-cpt { width: 100%; margin-top: 6px; color: #111111; }
                    .aq-cpt table { width: 100%; border-collapse: collapse; table-layout: fixed;
                        font-family: 'Oxanium', Arial, sans-serif; }
                    .aq-cpt thead th { background: #000000; color: #ffffff; border: 0;
                        border-bottom: 2px solid #B9E856; padding: 4px 3px; font-size: 9px;
                        letter-spacing: .3px; text-transform: uppercase; text-align: center; }
                    .aq-cpt td { border: 1px solid #f1f1f3; padding: 3px; font-size: 9px;
                        vertical-align: top; word-break: break-word; background: #ffffff; }
                    .aq-cpt .num { text-align: right; }
                    .aq-cpt .ctr { text-align: center; }
                </style>

                <div class="aq-h">Conceptos</div>
                <div class="aq-h-rule"/>

                <table>
                    <thead>
                        <tr>
                            <th style="width:9%">Clave SAT</th>
                            <th style="width:8%">No. ident.</th>
                            <th style="width:27%">Descripción</th>
                            <th style="width:7%">Cantidad</th>
                            <th style="width:11%">Unidad</th>
                            <th style="width:9%">V. unitario</th>
                            <th style="width:9%">Importe</th>
                            <th style="width:7%">Desc.</th>
                            <th style="width:4%">Obj.</th>
                            <th style="width:9%">Impuestos</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="d_cfdi['conceptos']" t-as="c">
                            <td class="ctr"><span t-esc="c['clave_prod']"/></td>
                            <td class="ctr"><span t-esc="c['no_id']"/></td>
                            <td><span t-esc="c['descripcion']"/></td>
                            <td class="num"><span t-esc="c['cantidad']"/></td>
                            <td><span t-esc="c['clave_unidad']"/> <span t-esc="c['unidad']"/></td>
                            <td class="num"><span t-esc="c['valor_unitario']"/></td>
                            <td class="num"><span t-esc="c['importe']"/></td>
                            <td class="num"><span t-esc="c['descuento']"/></td>
                            <td class="ctr"><span t-esc="c['objeto_imp']"/></td>
                            <td class="imp">
                                <t t-foreach="c['traslados']" t-as="t">
                                    <span t-esc="t['impuesto_nombre']"/> <span t-esc="t['tipo']"/><br/>
                                    Base <span t-esc="t['base']"/><br/>
                                    <span t-esc="t['tipo_factor']"/> <span t-esc="t['tasa_disp']"/>: <span t-esc="t['importe']"/><br/>
                                </t>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </xpath>

        <!-- ============================================================ -->
        <!-- Validación SAT: QR + info + sellos + cadena original          -->
        <!-- ============================================================ -->
        <xpath expr="//div[hasclass('page')]" position="inside">
            <div t-if="d_cfdi.get('uuid')" class="aq-seals mt-1">
                <style>
                    .aq-seals { width: 100%; margin-top: 12px; font-family: 'Roboto', Arial, sans-serif;
                        font-size: 11px; line-height: 1.2; color: #111111;
                        page-break-inside: avoid; break-inside: avoid; }
                    .aq-seal-grid { width: 100%; border-collapse: collapse; table-layout: fixed; margin-bottom: 4px; }
                    .aq-qr { width: 156px; vertical-align: top; padding: 0 12px 0 0; background: #ffffff; }
                    .aq-qr img { width: 148px; height: 148px; border: 1px solid #ededf0;
                        padding: 3px; background: #ffffff; }
                    .aq-extra { vertical-align: top; font-family: 'Oxanium', Arial, sans-serif;
                        font-size: 11px; line-height: 1.85; padding: 0; background: #ffffff; }
                    .aq-extra b { color: #723FA0; font-weight: 700; }
                    .aq-seal-text { font-family: monospace; font-size: 11px; line-height: 1.25; color: #222222;
                        border: 1px solid #ededf0; padding: 4px 7px; word-break: normal;
                        white-space: normal; background: #ffffff; }
                    .aq-note { text-align: center; font-family: 'Oxanium', Arial, sans-serif; font-size: 9px;
                        letter-spacing: 1.5px; text-transform: uppercase; color: #9a9aa0; margin-top: 9px; }
                </style>

                <div class="aq-h">Validación SAT</div>
                <div class="aq-h-rule"/>

                <table class="aq-seal-grid">
                    <tr>
                        <td class="aq-qr">
                            <img t-if="d_cfdi.get('qr_b64')"
                                 t-att-src="'data:image/png;base64,%s' % d_cfdi['qr_b64']"/>
                        </td>
                        <td class="aq-extra">
                            <b>CFDI:</b> <span t-esc="d_cfdi['uuid']"/><br/>
                            <b>Certificado emisor:</b> <span t-esc="d_cfdi['no_certificado']"/> &#160;|&#160;
                            <b>Certificado SAT:</b> <span t-esc="d_cfdi['no_certificado_sat']"/><br/>
                            <b>Lugar expedición:</b> <span t-esc="d_cfdi['lugar_expedicion']"/><br/>
                            <b>Emisión:</b> <span t-esc="d_cfdi['fecha']"/> &#160;|&#160;
                            <b>Certificación:</b> <span t-esc="d_cfdi['fecha_timbrado']"/>
                        </td>
                    </tr>
                </table>

                <div class="aq-sh">Sello digital del CFDI</div>
                <div class="aq-sh-rule"/>
                <div class="aq-seal-text">
                    <t t-foreach="d_cfdi.get('sello_cfdi_lines', [])" t-as="line">
                        <span t-esc="line"/><br/>
                    </t>
                </div>

                <div class="aq-sh">Sello digital del SAT</div>
                <div class="aq-sh-rule"/>
                <div class="aq-seal-text">
                    <t t-foreach="d_cfdi.get('sello_sat_lines', [])" t-as="line">
                        <span t-esc="line"/><br/>
                    </t>
                </div>

                <div class="aq-sh">Cadena original del complemento de certificación del SAT</div>
                <div class="aq-sh-rule"/>
                <div class="aq-seal-text">
                    <t t-foreach="d_cfdi.get('cadena_sat_lines', [])" t-as="line">
                        <span t-esc="line"/><br/>
                    </t>
                </div>

                <div class="aq-note">Representación impresa de un CFDI</div>
            </div>
        </xpath>

    </template>
</odoo>