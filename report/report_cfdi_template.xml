<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Extiende el reporte BASE de factura (account.report_invoice_document),
        que es el que se envía por correo y el que se imprime con el botón
        principal. Respeta el external layout configurado (bubble, boxed, etc.).

        El pie nativo del CFDI de la localización mexicana se desactiva en
        report_disable_l10n_mx.xml; aquí se inyecta nuestra propia versión,
        compacta:
          - Folio fiscal (UUID) en una tabla interna dentro del bloque de
            información existente.
          - Sellos digitales, cadena original, QR e Información Extra al pie.
        Todo se muestra únicamente cuando la factura ya está timbrada.
    -->
    <template id="report_invoice_document_cfdi_aq" inherit_id="account.report_invoice_document">

        <!-- ============================================================ -->
        <!-- Folio fiscal (tabla interna) en el bloque de información      -->
        <!-- ============================================================ -->
        <xpath expr="//div[@id='informations']" position="inside">
            <t t-set="d_cfdi" t-value="o._aq_get_cfdi_data()"/>
            <div t-if="d_cfdi.get('uuid')" class="col-12 aq-cfdi mt-1" name="aq_cfdi_fiscal">
                <style>
                    .aq-cfdi { font-size: 7px; color: #222; }
                    .aq-cfdi table { width: 100%; border-collapse: collapse; }
                    .aq-cfdi .aq-tbl td { padding: 0 6px 0 0; vertical-align: top; }
                    .aq-cfdi .k { font-weight: bold; white-space: nowrap; }
                    .aq-seals .seal-h { background: #7a7a85; color: #fff;
                        text-align: center; font-weight: bold; font-size: 6.5px;
                        padding: 1px; margin-top: 5px; }
                    .aq-seals .seal { font-size: 5.5px; word-break: break-all;
                        line-height: 1.2; padding: 1px; }
                    .aq-seals .qrbox { width: 90px; vertical-align: top; }
                    .aq-seals .qrbox img { width: 85px; height: 85px; }
                    .aq-seals .cert td { padding: 0 4px 0 0; vertical-align: top; }
                    .aq-seals .info-extra { font-size: 5.5px; line-height: 1.3; margin-top: 4px; }
                    .aq-seals .note { text-align: center; font-size: 6px; color: #555;
                        margin-top: 6px; border-top: 1px solid #ccc; padding-top: 3px; }
                </style>
                <table class="aq-tbl">
                    <tr>
                        <td class="k" style="width:12%">Folio fiscal:</td>
                        <td><span t-esc="d_cfdi['uuid']"/></td>
                    </tr>
                </table>
            </div>
        </xpath>

        <!-- ============================================================ -->
        <!-- Pie: sellos, cadena original, QR e Información Extra          -->
        <!-- ============================================================ -->
        <xpath expr="//div[hasclass('page')]" position="inside">
            <t t-set="d_seal" t-value="o._aq_get_cfdi_data()"/>
            <div t-if="d_seal.get('uuid')" class="aq-cfdi aq-seals mt-2">
                <div class="seal-h">Sello digital del CFDI</div>
                <div class="seal"><span t-esc="d_seal['sello_cfdi']"/></div>

                <div class="seal-h">Sello digital del SAT</div>
                <div class="seal"><span t-esc="d_seal['sello_sat']"/></div>

                <div class="seal-h">Cadena original del complemento de certificación digital del SAT</div>
                <table>
                    <tr>
                        <td class="qrbox">
                            <img t-if="d_seal.get('qr_b64')"
                                 t-att-src="'data:image/png;base64,%s' % d_seal['qr_b64']"/>
                        </td>
                        <td style="vertical-align:top">
                            <div class="seal"><span t-esc="d_seal['cadena_sat']"/></div>
                        </td>
                    </tr>
                </table>

                <div class="info-extra">
                    <b>Información Extra:</b>
                    Certificado del emisor: <span t-esc="d_seal['no_certificado']"/> |
                    Certificado SAT: <span t-esc="d_seal['no_certificado_sat']"/> |
                    Lugar de expedición: <span t-esc="d_seal['lugar_expedicion']"/> |
                    Régimen Fiscal: <span t-esc="d_seal['regimen_emisor']"/> |
                    Fecha de Emisión: <span t-esc="d_seal['fecha']"/> |
                    Fecha de Certificación: <span t-esc="d_seal['fecha_timbrado']"/> |
                    Folio Fiscal: <span t-esc="d_seal['uuid']"/>
                </div>

                <div class="note">Este documento es una representación impresa de un CFDI.</div>
            </div>
        </xpath>

    </template>
</odoo>
