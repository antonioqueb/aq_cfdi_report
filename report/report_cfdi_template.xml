<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Extiende el reporte BASE de factura (account.report_invoice_document),
        que es el que se envía por correo y el que se imprime con el botón
        principal. Respeta el external layout configurado (bubble, boxed, etc.).

        IMPORTANTE: NO se desactiva ni se reemplaza el pie del CFDI que agrega
        la localización mexicana (l10n_mx_edi) — esa vista aporta estructura que
        el layout necesita; quitarla rompe el diseño. Aquí solo se:
          - Agrega el Folio fiscal (UUID) en el bloque de información existente,
            con el mismo formato de columna que los demás campos.
          - Reduce el tamaño de letra del contenido de la página (incluido el
            pie del CFDI nativo), sin tocar la estructura.
    -->
    <template id="report_invoice_document_cfdi_aq" inherit_id="account.report_invoice_document">

        <!-- Folio fiscal junto a Fecha / Uso / Forma de pago (mismo formato) -->
        <xpath expr="//div[@id='informations']" position="inside">
            <t t-set="d_cfdi" t-value="o._aq_get_cfdi_data()"/>
            <div t-if="d_cfdi.get('uuid')" class="col-auto col-3 mw-100 mb-2" name="aq_folio_fiscal">
                <strong>Folio fiscal:</strong>
                <p class="m-0" t-esc="d_cfdi['uuid']"/>
            </div>
        </xpath>

        <!-- Solo reduce el tamaño de letra; no cambia la estructura -->
        <xpath expr="//div[hasclass('page')]" position="inside">
            <style>
                .page { font-size: 11px; }
            </style>
        </xpath>

    </template>
</odoo>
