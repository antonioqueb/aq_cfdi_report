<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Extiende el reporte BASE de factura (account.report_invoice_document),
        que es el que se envía por correo y el que se imprime con el botón
        principal. Respeta el external layout configurado (bubble, boxed, etc.).

        Los sellos, la cadena original, el código de barras (QR) y la
        "Información Extra" del CFDI ya los agrega la localización mexicana
        (l10n_mx_edi) al pie del reporte base; aquí NO se vuelven a poner para
        evitar duplicados.

        Lo único que se inyecta es el Folio fiscal (UUID) dentro del bloque de
        información existente, junto a Fecha, Uso, Forma de pago, etc., y solo
        cuando la factura ya está timbrada.
    -->
    <template id="report_invoice_document_cfdi_aq" inherit_id="account.report_invoice_document">

        <!-- ============================================================ -->
        <!-- Folio fiscal dentro del bloque de información existente       -->
        <!-- ============================================================ -->
        <xpath expr="//div[@id='informations']" position="inside">
            <t t-set="d_cfdi" t-value="o._aq_get_cfdi_data()"/>
            <div t-if="d_cfdi.get('uuid')" class="col-auto col-3 mw-100 mb-2" name="aq_folio_fiscal">
                <strong>Folio fiscal:</strong>
                <p class="m-0" t-esc="d_cfdi['uuid']"/>
            </div>
        </xpath>

    </template>
</odoo>
