<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Extiende el reporte BASE de factura (account.report_invoice_document),
        que es el que se envía por correo y el que se imprime con el botón
        principal. Respeta el external layout configurado (bubble, boxed, etc.).

        La vista nativa del CFDI (l10n_mx_edi) se desactiva en
        report_disable_l10n_mx.xml; aquí se reconstruye todo con formato propio:
          - Datos del CFDI una sola vez (sin volver a parsear el XML / regenerar
            el QR).
          - Dos tarjetas compactas (Datos CFDI / Fiscal-Pago) bajo el bloque de
            información.
          - Pie indivisible (page-break-inside: avoid) con QR, información extra,
            sellos y cadena original.
        Todo solo cuando la factura está timbrada.
    -->
    <template id="report_invoice_document_cfdi_aq" inherit_id="account.report_invoice_document">

        <!-- Extrae los datos del CFDI UNA sola vez; queda en scope para los -->
        <!-- demás bloques (son hermanos posteriores dentro de .page).        -->
        <xpath expr="//div[@id='informations']" position="before">
            <t t-set="d_cfdi" t-value="o._aq_get_cfdi_data()"/>
        </xpath>

        <!-- ============================================================ -->
        <!-- Tarjetas fiscales compactas bajo el bloque de información     -->
        <!-- ============================================================ -->
        <xpath expr="//div[@id='informations']" position="after">
            <div t-if="d_cfdi.get('uuid')" class="aq-cfdi-card mt-1" name="aq_cfdi_fiscal">
                <style>
                    .aq-cfdi-card { font-size: 8px; line-height: 1.15; color: #222;
                        margin-top: 4px; margin-bottom: 6px; }
                    .aq-cfdi-wrap { width: 100%; border-collapse: collapse; table-layout: fixed; }
                    .aq-mini { width: 100%; border-collapse: collapse; table-layout: fixed;
                        border: 1px solid #bbb; }
                    .aq-mini th { font-size: 8px; padding: 2px 4px; background: #eeeeee;
                        text-align: left; border-bottom: 1px solid #bbb; }
                    .aq-mini td { font-size: 7.5px; padding: 2px 4px; vertical-align: top;
                        border-bottom: 1px solid #e5e5e5; word-break: break-word; }
                    .aq-mini td:first-child { width: 32%; font-weight: bold; white-space: nowrap; }
                </style>
                <table class="aq-cfdi-wrap">
                    <tr>
                        <td style="width:50%; padding-right:6px;">
                            <table class="aq-mini">
                                <tr><th colspan="2">Datos CFDI</th></tr>
                                <tr><td>Folio fiscal</td><td><span t-esc="d_cfdi['uuid']"/></td></tr>
                                <tr><td>Serie / Folio</td><td><span t-esc="d_cfdi['serie_folio']"/></td></tr>
                                <tr><td>Tipo</td><td><span t-esc="d_cfdi['tipo_comprobante']"/> - <span t-esc="d_cfdi['tipo_comprobante_nombre']"/></td></tr>
                                <tr><td>Emisión</td><td><span t-esc="d_cfdi['fecha']"/></td></tr>
                                <tr><td>Moneda</td><td><span t-esc="d_cfdi['moneda']"/></td></tr>
                            </table>
                        </td>
                        <td style="width:50%; padding-left:6px;">
                            <table class="aq-mini">
                                <tr><th colspan="2">Fiscal / Pago</th></tr>
                                <tr><td>Régimen emisor</td><td><span t-esc="d_cfdi['regimen_emisor']"/> - <span t-esc="d_cfdi['regimen_emisor_nombre']"/></td></tr>
                                <tr><td>Uso CFDI</td><td><span t-esc="d_cfdi['uso_cfdi']"/> - <span t-esc="d_cfdi['uso_cfdi_nombre']"/></td></tr>
                                <tr t-if="d_cfdi.get('forma_pago')"><td>Forma de pago</td><td><span t-esc="d_cfdi['forma_pago_label']"/></td></tr>
                                <tr><td>Método de pago</td><td><span t-esc="d_cfdi['metodo_pago_label']"/></td></tr>
                                <tr><td>CSD emisor</td><td><span t-esc="d_cfdi['no_certificado']"/></td></tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </div>
        </xpath>

        <!-- ============================================================ -->
        <!-- Pie indivisible: QR + info extra + sellos + cadena original   -->
        <!-- ============================================================ -->
        <xpath expr="//div[hasclass('page')]" position="inside">
            <div t-if="d_cfdi.get('uuid')" class="aq-seals mt-1">
                <style>
                    .aq-seals { font-size: 6px; line-height: 1.1; color: #222; width: 100%;
                        margin-top: 6px; page-break-inside: avoid; break-inside: avoid; }
                    .aq-seal-layout { width: 100%; border-collapse: collapse;
                        table-layout: fixed; margin-bottom: 3px; }
                    .aq-qr { width: 72px; vertical-align: top; }
                    .aq-qr img { width: 68px; height: 68px; }
                    .aq-extra { vertical-align: top; font-size: 6px; line-height: 1.2;
                        word-break: break-word; }
                    .aq-seal-title { font-weight: bold; font-size: 6.2px; background: #e8e8e8;
                        padding: 1px 3px; margin-top: 2px; }
                    .aq-seal-text { font-family: monospace; font-size: 5.3px; line-height: 1.05;
                        word-break: break-all; overflow-wrap: anywhere; padding: 1px 2px; }
                    .aq-note { text-align: center; font-size: 6px; margin-top: 3px;
                        border-top: 1px solid #ccc; padding-top: 2px; }
                </style>
                <table class="aq-seal-layout">
                    <tr>
                        <td class="aq-qr">
                            <img t-if="d_cfdi.get('qr_b64')"
                                 t-att-src="'data:image/png;base64,%s' % d_cfdi['qr_b64']"/>
                        </td>
                        <td class="aq-extra">
                            <b>CFDI:</b> <span t-esc="d_cfdi['uuid']"/><br/>
                            <b>Certificado emisor:</b> <span t-esc="d_cfdi['no_certificado']"/> |
                            <b>Certificado SAT:</b> <span t-esc="d_cfdi['no_certificado_sat']"/><br/>
                            <b>Lugar expedición:</b> <span t-esc="d_cfdi['lugar_expedicion']"/> |
                            <b>Emisión:</b> <span t-esc="d_cfdi['fecha']"/> |
                            <b>Certificación:</b> <span t-esc="d_cfdi['fecha_timbrado']"/>
                        </td>
                    </tr>
                </table>

                <div class="aq-seal-title">Sello digital del CFDI</div>
                <div class="aq-seal-text"><span t-esc="d_cfdi['sello_cfdi']"/></div>

                <div class="aq-seal-title">Sello digital del SAT</div>
                <div class="aq-seal-text"><span t-esc="d_cfdi['sello_sat']"/></div>

                <div class="aq-seal-title">Cadena original del complemento de certificación digital del SAT</div>
                <div class="aq-seal-text"><span t-esc="d_cfdi['cadena_sat']"/></div>

                <div class="aq-note">Este documento es una representación impresa de un CFDI.</div>
            </div>
        </xpath>

    </template>
</odoo>
