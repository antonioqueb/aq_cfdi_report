<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Extiende el reporte BASE de factura (account.report_invoice_document),
        que es el que se envía por correo y el que se imprime con el botón
        principal. Respeta el external layout configurado (bubble, boxed, etc.).

        La vista nativa del CFDI (l10n_mx_edi) se desactiva en
        report_disable_l10n_mx.xml; aquí se reconstruye todo con formato propio:
          - Datos del CFDI una sola vez (sin re-parsear el XML / regenerar QR).
          - Tabla fiscal única de 4 columnas (legible, ~9px).
          - Pie indivisible con QR, info extra, sellos y cadena original.

        Los sellos y la cadena se imprimen como LÍNEAS ya cortadas desde Python
        (_aq_split_text): wkhtmltopdf no rompe de forma confiable cadenas largas
        sin espacios, así que no dependemos de word-break/overflow-wrap.
    -->
    <template id="report_invoice_document_cfdi_aq" inherit_id="account.report_invoice_document">

        <!-- Extrae los datos del CFDI UNA sola vez; queda en scope para los -->
        <!-- demás bloques (son hermanos posteriores dentro de .page).        -->
        <xpath expr="//div[@id='informations']" position="before">
            <t t-set="d_cfdi" t-value="o._aq_get_cfdi_data()"/>
            <!-- Reduce el texto del cuerpo del reporte base (tabla de líneas,    -->
            <!-- referencia de pago, totales e importe con letra). El título h2   -->
            <!-- usa rem y no se ve afectado; las tablas CFDI fijan su propio px.  -->
            <style>
                .page { font-size: 9px; }
                .page .o_main_table th,
                .page .o_main_table td { padding: 2px 4px; }
            </style>
        </xpath>

        <!-- Oculta el bloque nativo de info (Fecha de factura / Fecha límite / -->
        <!-- Origen / Referencia) SOLO cuando hay CFDI; esos datos pasan a la    -->
        <!-- tabla fiscal de abajo. En facturas sin timbrar se conserva.         -->
        <xpath expr="//div[@id='informations']" position="attributes">
            <attribute name="t-att-style">d_cfdi.get('uuid') and 'display:none' or ''</attribute>
        </xpath>

        <!-- ============================================================ -->
        <!-- Tabla fiscal única (4 columnas) bajo el bloque de información -->
        <!-- ============================================================ -->
        <xpath expr="//div[@id='informations']" position="after">
            <div t-if="d_cfdi.get('uuid')" class="aq-cfdi mt-2" name="aq_cfdi_fiscal">
                <style>
                    .aq-cfdi { margin-top: 8px; margin-bottom: 10px; }
                    .aq-cfdi-info { width: 100%; border-collapse: collapse; table-layout: fixed;
                        font-size: 8.8px; line-height: 1.25; color: #222; border: 1px solid #aaa; }
                    .aq-cfdi-info td { padding: 3px 5px; vertical-align: top;
                        border-bottom: 1px solid #e1e1e1; word-break: normal; background: #f1f1f1; }
                    .aq-cfdi-info .k { width: 16%; font-weight: bold; white-space: nowrap; }
                    .aq-cfdi-info td:nth-child(2),
                    .aq-cfdi-info td:nth-child(4) { width: 35%; }
                </style>
                <table class="aq-cfdi-info">
                    <tr>
                        <td class="k">Folio fiscal</td>
                        <td colspan="3"><span t-esc="d_cfdi['uuid']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Serie / Folio</td>
                        <td><span t-esc="d_cfdi['serie_folio']"/></td>
                        <td class="k">Emisión</td>
                        <td><span t-esc="d_cfdi['fecha']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Fecha de factura</td>
                        <td><span t-field="o.invoice_date"/></td>
                        <td class="k">Fecha límite</td>
                        <td><span t-field="o.invoice_date_due"/></td>
                    </tr>
                    <tr>
                        <td class="k">Origen</td>
                        <td><span t-esc="o.invoice_origin"/></td>
                        <td class="k">Referencia</td>
                        <td><span t-esc="o.ref"/></td>
                    </tr>
                    <tr>
                        <td class="k">Tipo</td>
                        <td><span t-esc="d_cfdi['tipo_comprobante']"/> - <span t-esc="d_cfdi['tipo_comprobante_nombre']"/></td>
                        <td class="k">Moneda</td>
                        <td><span t-esc="d_cfdi['moneda']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Régimen emisor</td>
                        <td><span t-esc="d_cfdi['regimen_emisor']"/> - <span t-esc="d_cfdi['regimen_emisor_nombre']"/></td>
                        <td class="k">Uso CFDI</td>
                        <td><span t-esc="d_cfdi['uso_cfdi']"/> - <span t-esc="d_cfdi['uso_cfdi_nombre']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Forma de pago</td>
                        <td><span t-esc="d_cfdi['forma_pago_label']"/></td>
                        <td class="k">Método de pago</td>
                        <td><span t-esc="d_cfdi['metodo_pago_label']"/></td>
                    </tr>
                    <tr>
                        <td class="k">CSD emisor</td>
                        <td><span t-esc="d_cfdi['no_certificado']"/></td>
                        <td class="k">CSD SAT</td>
                        <td><span t-esc="d_cfdi['no_certificado_sat']"/></td>
                    </tr>
                </table>
            </div>
        </xpath>

        <!-- ============================================================ -->
        <!-- Pie indivisible: QR + info extra + sellos + cadena original   -->
        <!-- ============================================================ -->
        <xpath expr="//div[hasclass('page')]" position="inside">
            <div t-if="d_cfdi.get('uuid')" class="aq-seals mt-1">
                <style>
                    .aq-seals { width: 100%; margin-top: 8px; font-size: 6px; line-height: 1.15;
                        color: #222; page-break-inside: avoid; break-inside: avoid; }
                    .aq-seal-layout { width: 100%; border-collapse: collapse; table-layout: fixed;
                        border: 1px solid #999; margin-bottom: 3px; }
                    .aq-qr { width: 74px; vertical-align: top; padding: 2px; }
                    .aq-qr img { width: 68px; height: 68px; }
                    .aq-extra { vertical-align: top; font-size: 6.8px; line-height: 1.15; padding: 3px 5px; }
                    .aq-seal-title { font-weight: bold; font-size: 6.8px; background: #eeeeee;
                        border: 1px solid #999; border-bottom: 0; padding: 2px 4px; margin-top: 2px; }
                    .aq-seal-text { font-family: monospace; font-size: 5.8px; line-height: 1.15;
                        border: 1px solid #999; padding: 2px 4px; word-break: normal; white-space: normal; }
                    .aq-note { text-align: center; font-size: 6.8px; margin-top: 3px; }
                </style>
                <table class="aq-seal-layout">
                    <tr>
                        <td class="aq-qr">
                            <img t-if="d_cfdi.get('qr_b64')"
                                 t-att-src="'data:image/png;base64,%s' % d_cfdi['qr_b64']"/>
                        </td>
                        <td class="aq-extra">
                            <b>CFDI:</b> <span t-esc="d_cfdi['uuid']"/><br/>
                            <b>Certificado emisor:</b> <span t-esc="d_cfdi['no_certificado']"/> |
                            <b>Certificado SAT:</b> <span t-esc="d_cfdi['no_certificado_sat']"/><br/>
                            <b>Lugar expedición:</b> <span t-esc="d_cfdi['lugar_expedicion']"/> |
                            <b>Emisión:</b> <span t-esc="d_cfdi['fecha']"/> |
                            <b>Certificación:</b> <span t-esc="d_cfdi['fecha_timbrado']"/>
                        </td>
                    </tr>
                </table>

                <div class="aq-seal-title">Sello digital del CFDI</div>
                <div class="aq-seal-text">
                    <t t-foreach="d_cfdi.get('sello_cfdi_lines', [])" t-as="line">
                        <span t-esc="line"/><br/>
                    </t>
                </div>

                <div class="aq-seal-title">Sello digital del SAT</div>
                <div class="aq-seal-text">
                    <t t-foreach="d_cfdi.get('sello_sat_lines', [])" t-as="line">
                        <span t-esc="line"/><br/>
                    </t>
                </div>

                <div class="aq-seal-title">Cadena original del complemento de certificación digital del SAT</div>
                <div class="aq-seal-text">
                    <t t-foreach="d_cfdi.get('cadena_sat_lines', [])" t-as="line">
                        <span t-esc="line"/><br/>
                    </t>
                </div>

                <div class="aq-note">Este documento es una representación impresa de un CFDI.</div>
            </div>
        </xpath>

    </template>
</odoo>
