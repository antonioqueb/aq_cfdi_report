<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Extiende el reporte BASE de factura (account.report_invoice_document),
        que es el que se envía por correo y el que se imprime con el botón
        principal. Respeta el external layout configurado (bubble, boxed, etc.).
        Solo se inyecta:
          - Bloque de datos fiscales CFDI en la parte superior.
          - Sellos digitales, cadena original y QR en la parte inferior.
        Todo se muestra únicamente cuando la factura ya está timbrada.
    -->
    <template id="report_invoice_document_cfdi_aq" inherit_id="account.report_invoice_document">

        <!-- ============================================================ -->
        <!-- Parte superior: datos fiscales del CFDI                       -->
        <!-- ============================================================ -->
        <xpath expr="//div[@id='informations']" position="after">
            <t t-set="d_cfdi" t-value="o._aq_get_cfdi_data()"/>
            <div t-if="d_cfdi.get('uuid')" class="aq-cfdi aq-cfdi-top mt-2">
                <style>
                    .aq-cfdi { font-size: 9px; color: #222; }
                    .aq-cfdi table { width: 100%; border-collapse: collapse; }
                    .aq-cfdi-top table td { vertical-align: top; padding: 1px 6px 1px 0; }
                    .aq-cfdi-top .k { font-weight: bold; white-space: nowrap; }
                    .aq-cfdi-title { font-weight: bold; font-size: 9.5px;
                        text-transform: uppercase; letter-spacing: .3px;
                        border-bottom: 1px solid #b9b9c2; padding-bottom: 2px; margin-bottom: 3px; }
                    .aq-cfdi-seals .seal-h { background: #7a7a85; color: #fff;
                        text-align: center; font-weight: bold; font-size: 8px;
                        padding: 2px; margin-top: 8px; }
                    .aq-cfdi-seals .seal { font-size: 6.5px; word-break: break-all;
                        line-height: 1.25; padding: 2px 1px; }
                    .aq-cfdi-seals .qrbox { width: 120px; vertical-align: top; }
                    .aq-cfdi-seals .qrbox img { width: 115px; height: 115px; }
                    .aq-cfdi-seals .cert td { padding: 1px 4px 1px 0; vertical-align: top; }
                    .aq-cfdi-note { text-align: center; font-size: 7.5px; color: #555;
                        margin-top: 10px; border-top: 1px solid #ccc; padding-top: 5px; }
                </style>
                <div class="aq-cfdi-title">Datos fiscales (CFDI 4.0)</div>
                <table>
                    <tr>
                        <td class="k" style="width:15%">Folio fiscal (UUID):</td>
                        <td style="width:35%"><span t-esc="d_cfdi['uuid']"/></td>
                        <td class="k" style="width:17%">No. serie CSD:</td>
                        <td style="width:33%"><span t-esc="d_cfdi['no_certificado']"/></td>
                    </tr>
                    <tr>
                        <td class="k">RFC emisor:</td>
                        <td><span t-esc="d_cfdi['rfc_emisor']"/></td>
                        <td class="k">Régimen emisor:</td>
                        <td><span t-esc="d_cfdi['regimen_emisor']"/> - <span t-esc="d_cfdi['regimen_emisor_nombre']"/></td>
                    </tr>
                    <tr>
                        <td class="k">RFC receptor:</td>
                        <td><span t-esc="d_cfdi['rfc_receptor']"/></td>
                        <td class="k">Régimen receptor:</td>
                        <td><span t-esc="d_cfdi['regimen_receptor']"/> - <span t-esc="d_cfdi['regimen_receptor_nombre']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Uso CFDI:</td>
                        <td><span t-esc="d_cfdi['uso_cfdi']"/> - <span t-esc="d_cfdi['uso_cfdi_nombre']"/></td>
                        <td class="k">CP receptor:</td>
                        <td><span t-esc="d_cfdi['cp_receptor']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Efecto de comprobante:</td>
                        <td><span t-esc="d_cfdi['tipo_comprobante']"/> - <span t-esc="d_cfdi['tipo_comprobante_nombre']"/></td>
                        <td class="k">Exportación:</td>
                        <td><span t-esc="d_cfdi['exportacion']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Serie / Folio:</td>
                        <td><span t-esc="d_cfdi['serie']"/> <span t-esc="d_cfdi['folio']"/></td>
                        <td class="k">Lugar / fecha emisión:</td>
                        <td><span t-esc="d_cfdi['lugar_expedicion']"/> · <span t-esc="d_cfdi['fecha']"/></td>
                    </tr>
                    <tr>
                        <td class="k">Forma de pago:</td>
                        <td><span t-esc="d_cfdi['forma_pago']"/></td>
                        <td class="k">Método de pago:</td>
                        <td><span t-esc="d_cfdi['metodo_pago']"/></td>
                    </tr>
                </table>
            </div>
        </xpath>

        <!-- ============================================================ -->
        <!-- Parte inferior: sellos, cadena original y QR                 -->
        <!-- ============================================================ -->
        <xpath expr="//div[hasclass('page')]" position="inside">
            <t t-set="d_seal" t-value="o._aq_get_cfdi_data()"/>
            <div t-if="d_seal.get('uuid')" class="aq-cfdi aq-cfdi-seals mt-3">
                <div class="seal-h">Sello digital del CFDI</div>
                <div class="seal"><span t-esc="d_seal['sello_cfdi']"/></div>

                <div class="seal-h">Sello digital del SAT</div>
                <div class="seal"><span t-esc="d_seal['sello_sat']"/></div>

                <div class="seal-h">Cadena original del complemento de certificación digital del SAT</div>
                <table>
                    <tr>
                        <td class="qrbox">
                            <img t-if="d_seal.get('qr_b64')"
                                 t-att-src="'data:image/png;base64,%s' % d_seal['qr_b64']"/>
                        </td>
                        <td style="vertical-align:top">
                            <div class="seal"><span t-esc="d_seal['cadena_sat']"/></div>
                            <table class="cert" style="margin-top:4px">
                                <tr>
                                    <td class="k" style="width:32%">RFC proveedor certif.:</td>
                                    <td><span t-esc="d_seal['rfc_pac']"/></td>
                                </tr>
                                <tr>
                                    <td class="k">No. serie certificado SAT:</td>
                                    <td><span t-esc="d_seal['no_certificado_sat']"/></td>
                                </tr>
                                <tr>
                                    <td class="k">Fecha y hora de certificación:</td>
                                    <td><span t-esc="d_seal['fecha_timbrado']"/></td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>

                <div class="aq-cfdi-note">
                    Este documento es una representación impresa de un CFDI.<br/>
                    El logotipo de esta factura es responsabilidad única y exclusiva de quien la emite;
                    el SAT queda relevado de cualquier obligación que derive de ello.
                </div>
            </div>
        </xpath>

    </template>
</odoo>
